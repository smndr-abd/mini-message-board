<!DOCTYPE html>
<html>
<head>
  <title>New Message</title>
</head>
<body>

  <h1>Create New Message</h1>

  <form method="POST" action="/new">

    <div>
      <label>Name:</label>
      <input
        type="text"
        name="messageUser"
        required
      >
    </div>

    <br>

    <div>
      <label>Message:</label>
      <input
        type="text"
        name="messageText"
        required
      >
    </div>

    <br>

    <button type="submit">
      Submit
    </button>

  </form>

</body>
</html>
