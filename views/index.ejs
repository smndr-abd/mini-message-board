<!DOCTYPE html>
<html>
<head>
  <title><%= title %></title>
</head>
<body>

  <h1>Mini Messageboard</h1>

  <a href="/new">Add New Message</a>

  <hr>

  <% messages.forEach((message, index) => { %>

    <div>
      <h3><%= message.user %></h3>

      <p><%= message.text %></p>

      <small><%= message.added %></small>

      <br>

      <a href="/message/<%= index %>">Open</a>
    </div>

    <hr>

  <% }) %>

</body>
</html>
